# Copy to .env and fill in. docker-compose sets KUMA_URL for you.

# Uptime Kuma API key, created in the Kuma UI under Settings -> API Keys.
# It is used as the HTTP Basic-auth username for the /metrics endpoint
# (password is blank).
KUMA_METRICS_TOKEN=

# AWTRIX 3 clock. Host or IP; "http://" is optional.
AWTRIX_HOST=192.168.1.50

# --- Only needed for the `provision` tool (monitors as code) ---
# Kuma ADMIN login (the account you create on Kuma's first-run screen). The API
# key above does NOT grant API access, so the sync tool needs these.
KUMA_USERNAME=
KUMA_PASSWORD=

# --- Optional (defaults shown) ---
# Custom-app name shown in the AWTRIX loop.
# AWTRIX_APP_NAME=health
# How often to scrape Kuma and push the tile.
# PUSH_INTERVAL_SECONDS=60
# Tile auto-expires this many seconds after the last push. Keep it a few push
# intervals so a healthy monitor never flickers out, but short enough that a
# dead host clears the tile promptly.
# TILE_LIFETIME_SECONDS=180
# HTTP timeout for both the Kuma scrape and the AWTRIX push.
# HTTP_TIMEOUT_SECONDS=10
# LOG_LEVEL=INFO
